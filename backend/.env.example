# ══════════════════════════════════════════════════════════════════════════════
#  Homly — Plantilla de variables de entorno
#  Copia este archivo a .env y rellena los valores reales.
#  NUNCA pongas credenciales reales en este archivo.
# ══════════════════════════════════════════════════════════════════════════════
#
#  Para generar un SECRET_KEY seguro ejecuta:
#    python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters + string.digits + '!@#$%^&*(-_=+)') for _ in range(64)))"
#
#  Para generar un DB_PASSWORD seguro ejecuta:
#    python3 -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters + string.digits) for _ in range(28)))"
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Seguridad ──────────────────────────────────────────────────────────────────
# Mínimo 50 caracteres aleatorios. Obligatorio cambiar en producción.
SECRET_KEY=CAMBIA-ESTO-POR-UNA-CLAVE-ALEATORIA-DE-50-CARACTERES
DEBUG=True

# ── Hosts / CORS ───────────────────────────────────────────────────────────────
# En producción: el dominio real, ej: homly.com.mx,www.homly.com.mx
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# En producción agregar también:
# CSRF_TRUSTED_ORIGINS=https://homly.com.mx,https://www.homly.com.mx

# ── Base de datos ──────────────────────────────────────────────────────────────
# Usar contraseña de mínimo 20 caracteres en producción.
# Después de cambiarla, ejecutar en psql:
#   ALTER USER <DB_USER> WITH PASSWORD '<nueva_contraseña>';
DB_NAME=homly_db
DB_USER=admin
DB_PASSWORD=CAMBIA-ESTO-POR-UNA-CONTRASENA-ROBUSTA
DB_HOST=localhost
DB_PORT=5432

# ── Email SMTP ──────────────────────────────────────────────────────────────────
# Descomenta y configura para enviar correos reales.
# El backend usa consola (imprime en terminal) si no hay credenciales y DEBUG=True.
#
# Proveedores comunes:
#   Gmail         → smtp.gmail.com       puerto 587  TLS=True  (usa App Password)
#   Outlook/M365  → smtp.office365.com   puerto 587  TLS=True
#   Puerto 465    → EMAIL_USE_SSL=True   EMAIL_USE_TLS=False
#
#EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USE_TLS=True
#EMAIL_USE_SSL=False
#EMAIL_HOST_USER=tucorreo@gmail.com
#EMAIL_HOST_PASSWORD=tu_app_password
#DEFAULT_FROM_EMAIL=tucorreo@gmail.com
#HOMLY_NOREPLY_EMAIL=noreply@homly.com.mx
#HOMLY_APP_URL=https://homly.com.mx/login
